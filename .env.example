# ━━━ Saturn Environment Variables ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Copy this to .env and fill in your values
# Saturn is ONE INSTANCE PER REPO — configure the repo it watches below.

# ── Anthropic (Claude) ──
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── The repo this Saturn instance watches ──
# Saturn maintains a persistent bare clone and uses git worktrees per task.
REPO_URL=https://gitlab.yourcompany.com/group/repo.git
REPO_LOCAL_PATH=/data/saturn/repo
WORKTREE_BASE_DIR=/data/saturn/tasks

# ── GitLab (for MR creation) ──
GITLAB_URL=https://gitlab.yourcompany.com
GITLAB_TOKEN=glpat-...
GITLAB_PROJECT_ID=group/repo
GITLAB_DEFAULT_BRANCH=main

# ── Zoho Cliq ──
CLIQ_WEBHOOK_TOKEN=your-cliq-verification-token
CLIQ_BOT_API_URL=https://cliq.zoho.com/api/v2/channelsbyname/your-channel/message
CLIQ_AUTH_TOKEN=your-zoho-oauth-token

# ── Server ──
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ── Agent ──
MAX_LOOP_ITERATIONS=20
THINKING_BUDGET_TOKENS=10000

