# ═══════════════════════════════════════════════════════════════════════════
# Saturn Environment Configuration for zdpas
# ═══════════════════════════════════════════════════════════════════════════
#
# Saturn uses a SEPARATE DPAAS_HOME to avoid conflicts with GitLab runner.
#
# Directory Structure:
#   /data/saturn/
#   ├── repo/                  # Bare clone of zdpas
#   ├── worktrees/             # Task-specific worktrees
#   │   └── SATURN-XXXX/       # Each task gets its own worktree
#   └── dpaas/                 # Saturn's own DPAAS_HOME (isolated)
#       └── zdpas/
#           └── spark/
#               ├── app_blue/  # dpaas.jar compiled by Saturn
#               ├── jars/      # Dependencies (from dpaas.tar.gz)
#               ├── lib/       # Libraries
#               └── resources/ # Config files
#
# GitLab Runner's DPAAS_HOME (unchanged):
#   /opt/dpaas/                # GitLab runner uses this
#
# ═══════════════════════════════════════════════════════════════════════════

# ── Saturn's Isolated DPAAS_HOME ──
# This is SEPARATE from GitLab runner's /opt/dpaas
SATURN_DPAAS_HOME=/data/saturn/dpaas

# ── Source of pre-built artifacts ──
# Saturn fetches these from GitLab CI/CD cache or artifacts
DPAAS_TAR_SOURCE=cache          # "cache" = use CI/CD cache, "build" = build from scratch
DPAAS_TAR_URL=                  # Optional: direct URL to dpaas.tar.gz

# ── GitLab Runner's DPAAS_HOME (for reference only) ──
# Saturn will copy dependencies FROM here if DPAAS_TAR_SOURCE=gitlab_runner
GITLAB_RUNNER_DPAAS_HOME=/opt/dpaas

# ── Build File Home (for datastore.json, build.xml, etc.) ──
SATURN_BUILD_FILE_HOME=/home/gitlab-runner/build-files

