# ═══════════════════════════════════════════════════════════════════════════
# Saturn Rules Configuration for ZDPAS — Incremental Testing
# ═══════════════════════════════════════════════════════════════════════════
#
# This enables INCREMENTAL testing — Saturn only runs tests for modules
# affected by the code changes, not the entire test suite.
#
# ═══════════════════════════════════════════════════════════════════════════

version: 1

incremental:
  compile_strategy: "full"

  # ─────────────────────────────────────────────────────────────────────────
  # Module Mapping — Maps file paths to logical module names
  # ─────────────────────────────────────────────────────────────────────────
  module_mapping:
    - path: "source/com/zoho/dpaas/transformer"
      module: "transformer"
    - path: "source/com/zoho/dpaas/dataframe"
      module: "dataframe"
    - path: "source/com/zoho/dpaas/storage"
      module: "storage"
    - path: "source/com/zoho/dpaas/util"
      module: "util"
    - path: "source/com/zoho/dpaas/context"
      module: "context"
    - path: "source/com/zoho/dpaas/query"
      module: "query"
    - path: "source/com/zoho/dpaas/udf"
      module: "udf"
    - path: "source/com/zoho/dpaas/common"
      module: "common"
    - path: "source/com/zoho/dpaas/parser"
      module: "parser"

  # ─────────────────────────────────────────────────────────────────────────
  # Test Mapping — Maps modules to ScalaTest patterns
  # ─────────────────────────────────────────────────────────────────────────
  test_mapping:
    transformer:
      pattern: "-w com.zoho.dpaas.transformer"
    dataframe:
      pattern: "-w com.zoho.dpaas.dataframe"
    storage:
      pattern: "-w com.zoho.dpaas.storage"
    util:
      pattern: "-w com.zoho.dpaas.util"
    context:
      pattern: "-w com.zoho.dpaas.context"
    query:
      pattern: "-w com.zoho.dpaas.query"
    udf:
      pattern: "-w com.zoho.dpaas.udf"
    common:
      pattern: "-w com.zoho.dpaas.common"
    parser:
      pattern: "-w com.zoho.dpaas.parser"

